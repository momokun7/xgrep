{
  "name": "xgrep",
  "version": "0.1.5",
  "description": "Ultra-fast indexed code search engine powered by trigram index. Native Rust bindings for Node.js.",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/momokun7/xgrep"
  },
  "keywords": [
    "search",
    "grep",
    "trigram",
    "index",
    "code-search",
    "rust",
    "napi"
  ],
  "author": "nakui",
  "license": "MIT",
  "homepage": "https://github.com/momokun7/xgrep",
  "engines": {
    "node": ">= 14"
  },
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build",
    "test": "node __test__/index.mjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "napi": {
    "name": "xgrep",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "xgrep.*.node"
  ]
}
